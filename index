<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ACBA Digital — 4 Homepage Concepts</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   PRESENTATION LAYER
   ═══════════════════════════════════════════════════════ */
:root {
  --dark: #0B1120;
  --navy: #162032;
  --teal: #00A688;
  --accent: #2563EB;
  --text-w: #E2E8F0;
  --text-m: #94A3B8;
  --text-d: #64748B;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--dark);
  background-image:
    radial-gradient(ellipse 80% 60% at 20% 10%, rgba(0,166,136,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 90%, rgba(37,99,235,0.05) 0%, transparent 60%);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

.header {
  text-align: center;
  padding: 56px 24px 40px;
}
.header .eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3.5px;
  color: var(--teal);
  margin-bottom: 16px;
  text-transform: uppercase;
}
.header h1 {
  font-size: 38px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.8px;
  line-height: 1.15;
  margin-bottom: 12px;
}
.header .desc {
  font-size: 15px;
  color: var(--text-m);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.65;
}
.header .protocol {
  display: inline-block;
  margin-top: 16px;
  padding: 8px 18px;
  border-radius: 24px;
  background: rgba(0,166,136,0.1);
  border: 1px solid rgba(0,166,136,0.2);
  font-size: 12px;
  font-weight: 600;
  color: var(--teal);
  letter-spacing: 0.2px;
}

/* ═══ GRID ═══ */
.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  padding: 0 24px 80px;
  max-width: 1460px;
  margin: 0 auto;
}
@media (max-width: 1280px) { .grid { grid-template-columns: repeat(2, 1fr); gap: 36px; max-width: 780px; } }
@media (max-width: 680px) { .grid { grid-template-columns: 1fr; max-width: 380px; } }

.col { display: flex; flex-direction: column; align-items: center; }

/* ═══ CONCEPT LABEL ═══ */
.label { text-align: center; margin-bottom: 16px; }
.label .tag {
  font-size: 10px; font-weight: 700; letter-spacing: 2.5px;
  color: var(--teal); margin-bottom: 5px;
}
.label h2 {
  font-size: 18px; font-weight: 800; color: #fff;
  letter-spacing: -0.3px; margin-bottom: 3px;
}
.label .sub { font-size: 11px; color: var(--text-d); font-weight: 500; }

/* Format badge below label */
.format-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 12px; border-radius: 20px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.8px;
  margin-bottom: 12px;
}
.fb-blue { background: rgba(37,99,235,0.12); color: #60A5FA; border: 1px solid rgba(37,99,235,0.2); }
.fb-purple { background: rgba(124,58,237,0.12); color: #A78BFA; border: 1px solid rgba(124,58,237,0.2); }
.fb-green { background: rgba(16,185,129,0.12); color: #6EE7B7; border: 1px solid rgba(16,185,129,0.2); }
.fb-orange { background: rgba(245,158,11,0.12); color: #FCD34D; border: 1px solid rgba(245,158,11,0.2); }

/* ═══════════════════════════════════════════════════════
   PHONE FRAME — iOS-like device
   ═══════════════════════════════════════════════════════ */
.device {
  width: 100%; max-width: 310px;
  background: #1C1C1E;
  border-radius: 46px;
  padding: 10px;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.05),
    0 30px 80px rgba(0,0,0,0.55),
    0 10px 30px rgba(0,0,0,0.3);
  position: relative;
}
.device::before {
  content: '';
  position: absolute;
  top: 10px; left: 50%;
  transform: translateX(-50%);
  width: 100px; height: 28px;
  background: #1C1C1E;
  border-radius: 0 0 18px 18px;
  z-index: 10;
}
.screen {
  background: #FFFFFF;
  border-radius: 38px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 640px;
}

/* ═══════════════════════════════════════════════════════
   IN-PHONE UI SYSTEM  (iOS-inspired, system font)
   ═══════════════════════════════════════════════════════ */
.screen, .screen * {
  font-family: -apple-system, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', sans-serif;
}

/* ─── Status Bar ─── */
.statusbar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 28px 2px;
  font-size: 14px; font-weight: 600; color: #000;
  flex-shrink: 0;
}
.sb-right { display: flex; gap: 5px; align-items: center; }
.sb-right svg { width: 16px; height: 16px; }

/* ─── Top Navigation ─── */
.topnav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 6px 16px 10px;
  flex-shrink: 0;
}
.tn-left {}
.tn-greet { font-size: 12px; color: #8E8E93; font-weight: 500; }
.tn-name { font-size: 17px; font-weight: 700; color: #000; margin-top: 1px; letter-spacing: -0.2px; }
.tn-right { display: flex; gap: 8px; align-items: center; }
.tn-btn {
  width: 34px; height: 34px; border-radius: 50%;
  background: #F2F2F7; display: flex; align-items: center; justify-content: center;
}
.tn-btn svg { width: 17px; height: 17px; color: #3C3C43; }
.tn-avatar {
  width: 34px; height: 34px; border-radius: 50%;
  background: linear-gradient(135deg, #007AFF, #5856D6);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: #fff;
}

/* ─── Scroll Area ─── */
.content {
  flex: 1; overflow-y: auto; background: #F2F2F7;
  scrollbar-width: none;
}
.content::-webkit-scrollbar { display: none; }

/* ─── Bottom Tab Bar ─── */
.tabbar {
  display: flex; justify-content: space-around; align-items: center;
  padding: 6px 2px 20px;
  background: rgba(255,255,255,0.97);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 0.5px solid rgba(0,0,0,0.08);
  flex-shrink: 0;
}
.tab {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  font-size: 10px; font-weight: 500; color: #8E8E93;
  min-width: 48px; padding: 2px 0;
  text-decoration: none;
}
.tab.active { color: #007AFF; }
.tab svg { width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
.tab.active svg { stroke-width: 1.8; }
/* Payments center tab — subtle emphasis */
.tab.center svg { width: 26px; height: 26px; }
.tab.center.active { color: #007AFF; }

/* ═══════════════════════════════════════════════════════
   SHARED UI COMPONENTS
   ═══════════════════════════════════════════════════════ */

/* ─── Balance Hero Card ─── */
.bal-hero {
  margin: 8px 16px; padding: 20px 18px; border-radius: 20px;
  color: #fff; position: relative; overflow: hidden;
}
.bal-hero.blue-grad { background: linear-gradient(145deg, #1D4ED8, #2563EB 40%, #3B82F6); }
.bal-hero .glow {
  position: absolute; top: -40px; right: -20px;
  width: 120px; height: 120px; border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.bal-hero .glow2 {
  position: absolute; bottom: -30px; left: -20px;
  width: 80px; height: 80px; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.bh-label { font-size: 11px; font-weight: 500; opacity: 0.75; margin-bottom: 6px; }
.bh-amount { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; }
.bh-sub { font-size: 10px; opacity: 0.6; font-weight: 500; margin-top: 6px; }
.bh-chips { display: flex; gap: 6px; margin-top: 12px; }
.bh-chip {
  padding: 4px 10px; border-radius: 10px;
  background: rgba(255,255,255,0.15);
  font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.9);
  backdrop-filter: blur(4px);
}

/* ─── Mini Balance Row ─── */
.mini-bal {
  margin: 8px 16px; padding: 14px 16px; border-radius: 16px;
  background: #fff;
  display: flex; justify-content: space-between; align-items: center;
}
.mb-lbl { font-size: 11px; color: #8E8E93; font-weight: 500; }
.mb-amt { font-size: 21px; font-weight: 800; color: #000; letter-spacing: -0.4px; }
.mb-link { font-size: 11px; font-weight: 600; color: #007AFF; }

/* ─── Quick Actions ─── */
.qacts {
  display: flex; justify-content: space-around; padding: 8px 16px 4px; gap: 2px;
}
.qact { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.qact-ic {
  width: 46px; height: 46px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
}
.qact-ic svg { width: 20px; height: 20px; }
.qact span { font-size: 10px; font-weight: 500; color: #8E8E93; }

/* ─── Section Header ─── */
.sec {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 16px 6px;
}
.sec h3 { font-size: 15px; font-weight: 700; color: #000; letter-spacing: -0.2px; }
.sec .link { font-size: 12px; font-weight: 600; color: #007AFF; }

/* ─── Transaction Row ─── */
.txr { display: flex; align-items: center; padding: 10px 16px; gap: 12px; }
.txi {
  width: 38px; height: 38px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.txd { flex: 1; }
.txn { font-size: 13px; font-weight: 600; color: #000; }
.txt { font-size: 10px; color: #8E8E93; margin-top: 1px; }
.txa { font-size: 13px; font-weight: 700; text-align: right; }
.txa-neg { color: #000; }
.txa-pos { color: #34C759; }
.sep { height: 0.5px; background: #E5E5EA; margin: 0 16px; }

/* White card container */
.wcard {
  margin: 6px 16px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
}

/* ─── Account Scroll ─── */
.accs { display: flex; gap: 8px; padding: 4px 16px 2px; overflow-x: auto; scrollbar-width: none; }
.accs::-webkit-scrollbar { display: none; }
.acc {
  flex-shrink: 0; padding: 12px 14px; border-radius: 14px;
  background: #fff; min-width: 125px;
}
.acc-lbl { font-size: 10px; color: #8E8E93; font-weight: 500; margin-bottom: 4px; }
.acc-val { font-size: 15px; font-weight: 700; color: #000; }

/* ─── Exchange Bar ─── */
.exbar { display: flex; margin: 6px 16px; border-radius: 12px; background: #fff; overflow: hidden; }
.exi {
  flex: 1; padding: 8px; text-align: center;
  border-right: 0.5px solid #E5E5EA;
}
.exi:last-child { border-right: none; }
.exi-c { font-size: 11px; font-weight: 600; color: #000; }
.exi-r { font-size: 9px; color: #8E8E93; margin-top: 1px; }

/* ═══════════════════════════════════════════════════════
   CONCEPT A: FINANCE-FIRST — Unique Elements
   ═══════════════════════════════════════════════════════ */

/* Hero Banner Promo */
.promo-hero {
  margin: 6px 16px; padding: 16px; border-radius: 16px;
  background: linear-gradient(135deg, #EEF2FF, #DBEAFE);
  position: relative; overflow: hidden;
}
.promo-hero::after {
  content: ''; position: absolute; top: -20px; right: -20px;
  width: 100px; height: 100px; border-radius: 50%;
  background: rgba(37,99,235,0.06);
}
.ph-badge {
  position: absolute; top: 10px; right: 10px;
  background: #EF4444; color: #fff; font-size: 10px; font-weight: 700;
  padding: 3px 10px; border-radius: 12px; z-index: 1;
}
.ph-pill {
  display: inline-block; padding: 3px 9px; border-radius: 10px;
  background: #2563EB; color: #fff; font-size: 9px; font-weight: 700;
  margin-bottom: 6px;
}
.ph-title { font-size: 14px; font-weight: 700; color: #1E293B; margin-bottom: 2px; }
.ph-desc { font-size: 11px; color: #64748B; line-height: 1.4; }

/* Spending Chart */
.chart { padding: 14px 16px 12px; }
.chart-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.chart-head h4 { font-size: 13px; font-weight: 700; color: #000; }
.chart-head span { font-size: 10px; color: #8E8E93; font-weight: 500; }
.chart-bars { display: flex; align-items: flex-end; gap: 6px; height: 56px; }
.chart-bars .cb { flex: 1; border-radius: 4px 4px 0 0; }
.chart-labels { display: flex; gap: 6px; margin-top: 4px; }
.chart-labels span { flex: 1; text-align: center; font-size: 8px; color: #8E8E93; font-weight: 500; }

/* ═══════════════════════════════════════════════════════
   CONCEPT B: ACTION-FIRST — Unique Elements
   ═══════════════════════════════════════════════════════ */

/* Big Action Grid */
.bigactions {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 8px; padding: 10px 16px;
}
.bigact {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 6px; padding: 16px 4px; border-radius: 16px; background: #fff;
}
.bigact-icon {
  width: 44px; height: 44px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
}
.bigact-icon svg { width: 22px; height: 22px; }
.bigact span { font-size: 11px; font-weight: 600; color: #1C1C1E; }

/* Stories Strip */
.stories {
  display: flex; gap: 12px; padding: 8px 16px; overflow-x: auto; scrollbar-width: none;
}
.stories::-webkit-scrollbar { display: none; }
.story { display: flex; flex-direction: column; align-items: center; gap: 4px; flex-shrink: 0; }
.story-ring {
  width: 56px; height: 56px; border-radius: 50%; padding: 2.5px;
  background: conic-gradient(#007AFF 0%, #5856D6 30%, #AF52DE 60%, #FF2D55 100%);
}
.story-ring.viewed { background: #D1D1D6; }
.story-inner {
  width: 100%; height: 100%; border-radius: 50%;
  background: #fff; padding: 2px;
  display: flex; align-items: center; justify-content: center;
}
.story-img {
  width: 100%; height: 100%; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.story-lbl { font-size: 9px; font-weight: 500; color: #8E8E93; max-width: 56px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Recipients */
.recips { display: flex; gap: 14px; padding: 4px 16px 8px; overflow-x: auto; scrollbar-width: none; }
.recips::-webkit-scrollbar { display: none; }
.recip { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.recip-av {
  width: 46px; height: 46px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 700; color: #fff;
}
.recip-add {
  width: 46px; height: 46px; border-radius: 50%;
  background: #F2F2F7; border: 1.5px dashed #C7C7CC;
  display: flex; align-items: center; justify-content: center;
}
.recip-add svg { width: 18px; height: 18px; color: #8E8E93; }
.recip span { font-size: 10px; color: #8E8E93; font-weight: 500; }

/* ═══════════════════════════════════════════════════════
   CONCEPT C: ADAPTIVE/AI — Unique Elements
   ═══════════════════════════════════════════════════════ */

/* AI Insight Bar */
.ai-bar {
  margin: 8px 16px; padding: 12px 14px; border-radius: 14px;
  background: linear-gradient(135deg, #F0FDF4, #ECFDF5);
  border: 1px solid #A7F3D0;
  display: flex; align-items: center; gap: 10px;
}
.ai-spark { font-size: 20px; }
.ai-tag {
  font-size: 9px; font-weight: 700; color: #059669;
  text-transform: uppercase; letter-spacing: 0.5px;
}
.ai-msg { font-size: 12px; font-weight: 600; color: #065F46; margin-top: 1px; line-height: 1.35; }

/* Inline Contextual Card */
.icard {
  margin: 6px 16px; padding: 14px; border-radius: 16px;
  background: #fff;
  display: flex; gap: 12px; align-items: flex-start;
}
.ic-icon {
  width: 38px; height: 38px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 17px; flex-shrink: 0;
}
.ic-body { flex: 1; }
.ic-tag {
  font-size: 9px; font-weight: 700; color: #059669;
  text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 3px;
}
.ic-title { font-size: 13px; font-weight: 700; color: #000; margin-bottom: 2px; }
.ic-desc { font-size: 11px; color: #8E8E93; line-height: 1.4; }
.ic-cta { font-size: 11px; font-weight: 600; color: #007AFF; margin-top: 6px; display: inline-block; }

/* ═══════════════════════════════════════════════════════
   CONCEPT D: SUPER-APP — Unique Elements
   ═══════════════════════════════════════════════════════ */

/* Category Tabs */
.cattabs { display: flex; gap: 6px; padding: 6px 16px; overflow-x: auto; scrollbar-width: none; }
.cattabs::-webkit-scrollbar { display: none; }
.cattab {
  flex-shrink: 0; padding: 6px 14px; border-radius: 20px;
  font-size: 11px; font-weight: 600; color: #8E8E93;
  background: #fff; white-space: nowrap;
}
.cattab.on { background: #007AFF; color: #fff; }

/* Investment Widget */
.invest {
  margin: 6px 16px; padding: 14px 16px; border-radius: 16px; background: #fff;
}
.inv-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.inv-head h4 { font-size: 14px; font-weight: 700; color: #000; }
.inv-head .inv-chg { font-size: 12px; font-weight: 700; color: #34C759; }
.inv-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 7px 0; border-top: 0.5px solid #F2F2F7;
}
.inv-name { font-size: 12px; font-weight: 500; color: #3C3C43; }
.inv-val { font-size: 12px; font-weight: 700; }

/* Carousel */
.carousel-wrap { padding: 0 16px 8px; }
.carousel { display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none; }
.carousel::-webkit-scrollbar { display: none; }
.ccard {
  flex-shrink: 0; width: 140px; border-radius: 16px; background: #fff; overflow: hidden;
}
.cc-img {
  height: 72px; display: flex; align-items: center; justify-content: center; font-size: 30px;
}
.cc-body { padding: 10px 12px; }
.cc-body h5 { font-size: 12px; font-weight: 700; color: #000; margin-bottom: 2px; }
.cc-body p { font-size: 10px; color: #8E8E93; line-height: 1.35; }

/* ═══ FORMAT INDICATOR (inside phone) ═══ */
.fmt-pill {
  display: inline-flex; align-items: center; gap: 4px;
  margin: 8px 16px 2px; padding: 3px 10px; border-radius: 14px;
  font-size: 8px; font-weight: 700; letter-spacing: 0.7px;
  text-transform: uppercase;
}
.fmt-pill.blue { background: #EFF6FF; color: #2563EB; }
.fmt-pill.purple { background: #F5F3FF; color: #7C3AED; }
.fmt-pill.green { background: #ECFDF5; color: #059669; }
.fmt-pill.orange { background: #FFF7ED; color: #EA580C; }

/* ═══ PRINT ═══ */
@media print {
  body { background: #fff !important; }
  .device { box-shadow: 0 2px 12px rgba(0,0,0,0.12) !important; }
  .header h1, .label h2 { color: var(--dark) !important; }
  .header .desc, .label .sub { color: #64748B !important; }
}
</style>
</head>
<body>

<div class="header">
  <div class="eyebrow">ACBA Digital · Homepage Redesign · 2026</div>
  <h1>Homepage Concept Wireframes</h1>
  <div class="desc">Four strategic directions for the ACBA Digital banking app homepage. Each concept features a distinct information hierarchy and promotional format.</div>
  <div class="protocol">📋 Present without explanation → 15 sec silence → "What do you see?"</div>
</div>

<div class="grid">

<!-- ╔══════════════════════════════════════════════════════════╗
     ║  CONCEPT A — FINANCE-FIRST                              ║
     ╚══════════════════════════════════════════════════════════╝ -->
<div class="col">
  <div class="label">
    <div class="tag">CONCEPT A</div>
    <h2>Finance-First</h2>
    <div class="sub">Balance · Accounts · Financial State</div>
  </div>
  <div class="format-badge fb-blue">⭐ Hero Banner + Floating Badge</div>
  <div class="device">
    <div class="screen">

      <!-- Status Bar -->
      <div class="statusbar">
        <span>9:41</span>
        <div class="sb-right">
          <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2"><path d="M1 9l4-4 4 4"/><path d="M5 5v14"/></svg>
          <svg viewBox="0 0 24 24" fill="#000"><rect x="1" y="7" width="20" height="11" rx="2"/><path d="M23 11v3" stroke="#000" stroke-width="2"/></svg>
        </div>
      </div>

      <!-- Top Nav -->
      <div class="topnav">
        <div class="tn-left">
          <div class="tn-greet">Good morning 👋</div>
          <div class="tn-name">Ani Harutyunyan</div>
